  "disambiguation_rules": [
    {
      "ambiguous_word": "清理",
      "possible_meanings": [
        { "target": "地上的掉落物/箭矢/经验球", "command": "kill", "selector": "@e[type=item] / @e[type=arrow] / @e[type=xp_orb]" },
        { "target": "背包/物品栏里的物品", "command": "clear", "selector": "@s <itemName>" },
        { "target": "一片区域的方块", "command": "fill", "args": "<from> <to> air" },
        { "target": "身上的状态效果", "command": "effect", "args": "<target> clear" },
        { "target": "实体的标签", "command": "tag", "args": "<target> remove <tag>" }
      ],
      "decision_rule": "根据操作对象判断：实体→kill，背包物品→clear，方块→fill，效果→effect，标签→tag"
    },
    {
      "ambiguous_word": "清除",
      "possible_meanings": [
        { "target": "实体（怪物/掉落物/经验球等）", "command": "kill" },
        { "target": "玩家背包中的物品", "command": "clear" },
        { "target": "状态效果", "command": "effect ... clear" },
        { "target": "方块区域", "command": "fill ... air" }
      ],
      "decision_rule": "同'清理'"
    },
    {
      "ambiguous_word": "移除",
