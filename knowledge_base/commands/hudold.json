{
  "name": "hudold",
  "syntax": "/hudold <target: target> <visible: hide|reset> [hudElement: string]",
  "description": "旧版HUD控制命令",
  "category": "advanced",
  "parameters": [
    {
      "name": "target",
      "type": "target",
      "required": true,
      "description": "目标玩家"
    },
    {
      "name": "visible",
      "type": "hide|reset",
      "required": true,
      "description": "隐藏或重置HUD元素"
    },
    {
      "name": "hudElement",
      "type": "string",
      "required": false,
      "description": "HUD元素名称"
    }
  ],
  "examples": [
    {
      "input": "/hudold @a hide all",
      "description": "隐藏所有玩家的全部HUD元素"
    }
  ],
  "bedrock_specific_notes": "hudold是hud命令的旧版保留。建议使用hud命令。",
  "version_added": "1.20.0"
}