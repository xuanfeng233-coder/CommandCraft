{
  "name": "changesettingold",
  "syntax": "/changesettingold <setting: string> <value: string>",
  "description": "更改服务器设置（旧版changesetting）",
  "category": "server_admin",
  "parameters": [
    {
      "name": "setting",
      "type": "string",
      "required": true,
      "description": "设置项名称（如allow-cheats）"
    },
    {
      "name": "value",
      "type": "string",
      "required": true,
      "description": "设置值"
    }
  ],
  "examples": [
    {
      "input": "/changesettingold allow-cheats true",
      "description": "启用作弊功能"
    }
  ],
  "bedrock_specific_notes": "changesettingold是旧版本的changesetting命令保留。建议使用changesetting命令。",
  "version_added": "1.0.0"
}