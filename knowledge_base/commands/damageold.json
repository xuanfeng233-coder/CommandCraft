{
  "name": "damageold",
  "syntax": "/damageold <target: target> <amount: int> [cause: DamageCause] [entity: target]",
  "description": "旧版伤害命令",
  "category": "advanced",
  "parameters": [
    {
      "name": "target",
      "type": "target",
      "required": true,
      "description": "受到伤害的目标实体"
    },
    {
      "name": "amount",
      "type": "int",
      "required": true,
      "description": "伤害数值"
    },
    {
      "name": "cause",
      "type": "DamageCause",
      "required": false,
      "description": "伤害类型"
    },
    {
      "name": "entity",
      "type": "target",
      "required": false,
      "description": "伤害来源实体"
    }
  ],
  "examples": [
    {
      "input": "/damageold @e[type=zombie] 5 fire",
      "description": "对所有僵尸造成5点火焰伤害"
    }
  ],
  "bedrock_specific_notes": "damageold是damage命令的旧版保留。建议使用damage命令。",
  "version_added": "1.18.10"
}