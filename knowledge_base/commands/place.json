{
  "name": "place",
  "syntax": "/place feature <featureName: string> <position: x y z> | /place structure <structureName: string> <position: x y z> | /place jigsaw <pool: string> <startJigsawName: string> <maxDepth: int> <position: x y z>",
  "description": "在指定位置放置地物或结构",
  "category": "world_editing",
  "parameters": [
    {
      "name": "featureName",
      "type": "string",
      "required": true,
      "description": "地物名称"
    },
    {
      "name": "structureName",
      "type": "string",
      "required": true,
      "description": "结构名称"
    },
    {
      "name": "pool",
      "type": "string",
      "required": true,
      "description": "拼图结构池名称"
    },
    {
      "name": "startJigsawName",
      "type": "string",
      "required": true,
      "description": "起始拼图方块名称"
    },
    {
      "name": "maxDepth",
      "type": "int",
      "required": true,
      "description": "拼图最大递归深度",
      "range": "1-7"
    },
    {
      "name": "position",
      "type": "x y z",
      "required": true,
      "description": "放置位置坐标"
    }
  ],
  "examples": [
    {
      "input": "/place feature minecraft:oak_tree 100 64 100",
      "description": "在指定位置放置一棵橡树"
    },
    {
      "input": "/place structure minecraft:village 0 64 0",
      "description": "在指定位置放置村庄结构"
    }
  ],
  "bedrock_specific_notes": "place命令是基岩版1.21.40+新增的命令，用于放置世界生成的地物和结构。支持feature（地物）、structure（结构）和jigsaw（拼图结构）三种放置模式。",
  "version_added": "1.21.40"
}