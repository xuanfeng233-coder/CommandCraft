{
  "name": "inputpermissionold",
  "syntax": "/inputpermissionold set <player: target> <permission: string> <value: enabled|disabled>",
  "description": "旧版输入权限管理命令",
  "category": "advanced",
  "parameters": [
    {
      "name": "player",
      "type": "target",
      "required": true,
      "description": "目标玩家"
    },
    {
      "name": "permission",
      "type": "string",
      "required": true,
      "description": "权限类型：camera、movement"
    },
    {
      "name": "value",
      "type": "enabled|disabled",
      "required": true,
      "description": "启用或禁用该权限"
    }
  ],
  "examples": [
    {
      "input": "/inputpermissionold set @a movement disabled",
      "description": "禁止所有玩家移动"
    }
  ],
  "bedrock_specific_notes": "inputpermissionold是inputpermission命令的旧版保留。建议使用inputpermission命令。",
  "version_added": "1.19.0"
}