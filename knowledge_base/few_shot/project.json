  {
    "input": "做一个传送门系统，玩家站在铁块上就传送到另一个位置",
    "output": {
      "type": "project",
      "project_name": "方块传送门系统",
      "overview": "检测玩家脚下的铁块，触发传送到目标位置，传送后添加冷却标签防止重复触发",
      "phases": [
        {
          "phase_name": "传送检测与执行",
          "description": "持续检测站在铁块上的玩家并传送",
          "tasks": [
            {
              "task_id": "1",
              "description": "检测脚下铁块并传送玩家（带冷却）",
              "commands": ["execute", "tp", "tag"],
              "command_blocks": [
                {
                  "type": "repeating",
                  "conditional": false,
                  "needs_redstone": false,
                  "command": "/execute as @a[tag=!tp_cooldown] at @s if block ~ ~-1 ~ iron_block run tp @s 100 64 100",
                  "comment": "检测脚下铁块并传送（排除冷却中的玩家）"
                },
                {
                  "type": "chain",
                  "conditional": true,
                  "needs_redstone": false,
                  "command": "/tag @a[tag=!tp_cooldown] add tp_cooldown",
                  "comment": "传送成功后添加冷却标签"
                },
                {
                  "type": "chain",
                  "conditional": false,
                  "needs_redstone": false,
                  "command": "/execute as @a[tag=tp_cooldown] unless block ~ ~-1 ~ iron_block run tag @s remove tp_cooldown",
                  "comment": "离开铁块后移除冷却标签"
                }
              ],
              "dependencies": []
            }
          ]
        }
      ]
    },
    "commands_used": ["execute", "tp", "tag"]
  },
