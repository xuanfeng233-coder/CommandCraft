                {
                  "type": "chain",
                  "conditional": false,
                  "needs_redstone": false,
                  "command": "/scoreboard players set countdown timer 200",
                  "comment": "设置倒计时为200tick（10秒）"
                }
              ],
              "dependencies": []
            }
          ]
        },
        {
          "phase_name": "倒计时运行",
          "description": "持续减少计时器并在动作栏显示",
          "tasks": [
            {
              "task_id": "2",
              "description": "每tick减少计时器并显示",
              "commands": ["scoreboard", "titleraw", "execute"],
              "command_blocks": [
                {
                  "type": "repeating",
                  "conditional": false,
                  "needs_redstone": false,
                  "command": "/execute if score countdown timer matches 1.. run scoreboard players remove countdown timer 1",
                  "comment": "每tick减少倒计时（仅当>0时）"
                },
                {
                  "type": "chain",
                  "conditional": false,
                  "needs_redstone": false,
                  "command": "/execute if score countdown timer matches 1.. run titleraw @a actionbar {\"rawtext\":[{\"text\":\"§e倒计时: \"},{\"score\":{\"name\":\"countdown\",\"objective\":\"timer\"}}]}",
                  "comment": "在动作栏显示剩余时间"
                },
                {
                  "type": "chain",
                  "conditional": false,
                  "needs_redstone": false,
                  "command": "/execute if score countdown timer matches 0 run titleraw @a title {\"rawtext\":[{\"text\":\"§c§lGO!\"}]}",
                  "comment": "倒计时归零时显示开始标题"
